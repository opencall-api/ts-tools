  "license": "Apache-2.0",
  "homepage": "https://opencall-api.com/spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencall-api/ts-tools.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/opencall-api/ts-tools/issues"
  },
  "publishConfig": {
